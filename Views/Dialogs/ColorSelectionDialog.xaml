<Window x:Class="RealmStudioX.WPF.Views.Dialogs.ColorSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:RealmStudioX.WPF.Views.Dialogs"
        xmlns:controls="clr-namespace:RealmStudioX.WPF.Views.Controls"        
        mc:Ignorable="d"
        Background="#FF45443F"
        WindowStyle="None"        
        Title="ColorSelectionDialog" Height="560" Width="580">
    
    <!-- WindowChrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="0"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid Background="#FFDFDBD2">

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>            
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>            
            <RowDefinition Height="*"/>            
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>

        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- CUSTOM TITLE BAR -->
        <!-- ========================= -->
        <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#FF45443F">

            <controls:ColorSelectionTitleBar />

        </Border>

        <StackPanel Grid.Column="0" Grid.Row="1" Grid.RowSpan="5" Margin="10,0,10,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="240"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <controls:CompactPaletteControl
                    Grid.Row="1"
                    VerticalAlignment="Bottom"
                    HorizontalAlignment="Center"
                    Margin="0,6,0,6"
                    SelectedColor="{Binding CurrentColor, Mode=TwoWay}"/>
            </Grid>
            
        </StackPanel>
        
        <!-- RGB -->
        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,10,0,12">

            <TextBlock Text="RGB" FontWeight="Bold" Margin="0,0,0,6"/>

            <!-- R -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="R:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="255"
                    Value="{Binding R, Mode=TwoWay}"/>
                <TextBox Width="50"
                     Margin="8,0,0,0"
                     Text="{Binding R, Mode=TwoWay}"/>
            </StackPanel>

            <!-- G -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="G:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="255"
                    Value="{Binding G, Mode=TwoWay}"/>
                <TextBox Width="50"
                     Margin="8,0,0,0"
                     Text="{Binding G, Mode=TwoWay}"/>
            </StackPanel>

            <!-- B -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="B:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="255"
                    Value="{Binding B, Mode=TwoWay}"/>
                <TextBox Width="50"
                     Margin="8,0,0,0"
                     Text="{Binding B, Mode=TwoWay}"/>
            </StackPanel>
            <!-- A -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="A:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="255"
                    Value="{Binding A, Mode=TwoWay}"/>
                <TextBox Width="50"
                     Margin="8,0,0,0"
                     Text="{Binding A, Mode=TwoWay}"/>
            </StackPanel>
            <!-- HEX -->
            <StackPanel Orientation="Horizontal" Grid.Row="0" Grid.Column="1" Margin="0,12,0,0">

                <TextBlock Text="Hex:" Margin="0,0,10,0"/>

                <TextBox Width="120"
                 Text="{Binding Hex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,12,0,12">

            <TextBlock Text="HSL" FontWeight="Bold" Margin="0,0,0,6"/>

            <!-- H -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="H:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="360"
                    Value="{Binding H, Mode=TwoWay}"/>
                <TextBox Width="50"
                 Margin="8,0,0,0"
                 Text="{Binding H, Mode=TwoWay}"/>
            </StackPanel>

            <!-- S -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="S:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="100"
                    Value="{Binding S, Mode=TwoWay}"/>
                <TextBox Width="50"
                 Margin="8,0,0,0"
                 Text="{Binding S, Mode=TwoWay}"/>
            </StackPanel>

            <!-- L -->
            <StackPanel Orientation="Horizontal" Margin="0,2">
                <TextBlock Text="L:" Width="20" Margin="0,0,12,0"/>
                <Slider
                    Style="{StaticResource ModernSlider}"
                    Width="150"
                    Minimum="0" Maximum="100"
                    Value="{Binding L, Mode=TwoWay}"/>
                <TextBox Width="50"
                 Margin="8,0,0,0"
                 Text="{Binding L, Mode=TwoWay}"/>
            </StackPanel>

        </StackPanel>

        <!-- PREVIEW -->

        <Grid Grid.Row="3" Grid.Column="1" Height="60"
               Width="100"
               HorizontalAlignment="Right"
               Margin="0,0,20,12">

            <!-- Checkerboard background -->
            <Rectangle>
                <Rectangle.Fill>
                    <DrawingBrush TileMode="Tile"
                          Viewport="0,0,10,10"
                          ViewportUnits="Absolute">
                        <DrawingBrush.Drawing>
                            <DrawingGroup>

                                <!-- base -->
                                <GeometryDrawing Brush="White"
                                         Geometry="M0,0 H10 V10 H0 Z"/>

                                <!-- top-left square -->
                                <GeometryDrawing Brush="#CCC"
                                         Geometry="M0,0 H5 V5 H0 Z"/>

                                <!-- bottom-right square -->
                                <GeometryDrawing Brush="#CCC"
                                         Geometry="M5,5 H10 V10 H5 Z"/>

                            </DrawingGroup>
                        </DrawingBrush.Drawing>
                    </DrawingBrush>
                </Rectangle.Fill>
            </Rectangle>

            <!-- color -->
            <Border BorderBrush="#666"
            BorderThickness="1"
            Background="{Binding CurrentBrush}"/>

        </Grid>


        <StackPanel Grid.Row="4" Grid.Column="1"
                    Height="150"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,10,10,10">
            <Button Content="Ok"
                    Click="Ok_Click"
                    Style="{StaticResource FlatToolButton}"
                    Width="60"
                    Margin="0,0,10,0"
                    Height="60" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

            <Button Content="Cancel"
                    Click="Cancel_Click"
                    Style="{StaticResource FlatToolButton}"                    
                    Width="60"
                    Height="60" Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>
        </StackPanel>
        
    </Grid>
</Window>
