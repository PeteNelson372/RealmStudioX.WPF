<Window x:Class="RealmStudioX.WPF.Views.Dialogs.StartupDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wfi="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
        xmlns:wf="clr-namespace:SkiaSharp;assembly=SkiaSharp"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:views="clr-namespace:RealmStudioX.WPF.Views"
        Title="RealmStudioX"
        Width="1100"
        Height="700"
        Background="#1E1E1E"
        WindowStyle="None"
        ResizeMode="NoResize"
        Icon="../../Assets/realm_studio_icon.ico">

    <!-- WindowChrome -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="32"
                            ResizeBorderThickness="5"
                            CornerRadius="0"/>
    </shell:WindowChrome.WindowChrome>

    <Grid Margin="10" Background="#FFDFDBD2">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <!-- Custom Title Bar -->
            <RowDefinition Height="*"/>
            <!-- Main -->
            <RowDefinition Height="70"/>
            <!-- Buttons -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ========================= -->
        <!-- CUSTOM TITLE BAR -->
        <!-- ========================= -->
        <Border Grid.Row="0"
            Grid.ColumnSpan="3"
            Background="#FF45443F">

            <views:StartupDialogTitleBar />

        </Border>
        <!-- LEFT: Create New -->
        <Border Grid.Row="1" Grid.Column="0" Padding="10" BorderBrush="#CCC" BorderThickness="1">
            <StackPanel>

                <TextBlock Text="Create New Map"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <!-- Map Name -->
                <Grid>

                    <TextBox x:Name="MapNameBox"
                     Padding="4"
                     Margin="10,0,10,0"
                     Text="{Binding MapName, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Text="Enter Realm Name..."
                       Foreground="Gray"
                       Margin="18,0,0,0"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False" FontStyle="Italic">

                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=MapNameBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=MapNameBox}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>

                    </TextBlock>

                </Grid>

                <!-- Width -->

                <!-- Height -->

                <!-- Presets -->

                <!-- Theme -->
                <TextBlock/>
                <GroupBox Height="471" Header="Realm Type" Width="200" HorizontalAlignment="Left" Margin="10,0,0,0">
                    <ListBox x:Name="MapTypeList"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectedIndex="0">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Margin" Value="2"/>
                                <Setter Property="Padding" Value="4"/>
                                <Setter Property="Cursor" Value="Hand"/>

                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">

                                            <Border x:Name="Border"
                                                Background="#EEE"
                                                BorderBrush="#CCC"
                                                BorderThickness="1"
                                                CornerRadius="4"
                                                Padding="6">

                                                <StackPanel Orientation="Horizontal"
                                                    VerticalAlignment="Center">

                                                    <!-- Icon -->
                                                    <materialDesign:PackIcon Kind="{Binding Icon}"
                                                         Width="20"
                                                         Height="20"
                                                         Margin="0,0,8,0"
                                                         VerticalAlignment="Center"/>

                                                    <!-- Label -->
                                                    <TextBlock Text="{Binding Name}"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"/>

                                                </StackPanel>

                                            </Border>

                                            <ControlTemplate.Triggers>

                                                <!-- Selected -->
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Border"
                                                        Property="Background"
                                                        Value="#007ACC"/>
                                                    <Setter Property="Foreground"
                                                        Value="White"/>
                                                </Trigger>

                                                <!-- Hover -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border"
                                                        Property="Background"
                                                        Value="#DDD"/>
                                                </Trigger>

                                            </ControlTemplate.Triggers>

                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>

                    </ListBox>
                </GroupBox>
            </StackPanel>
        </Border>
        <StackPanel Grid.Row="2" Grid.Column="0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,30,20">

            <Button Content="Create"
                    Width="100"
                    Click="OnCreate"/>

        </StackPanel>

        <!-- RIGHT: Open Existing -->
        <Border Grid.Row="1" Grid.Column="2" Padding="10" BorderBrush="#CCC" BorderThickness="1">
            <StackPanel>

                <TextBlock Text="Open Existing Map"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                <ListBox x:Name="MapList"
                         Height="300"
                         Margin="0,0,0,10"/>

                <Button Content="Browse..."
                        Click="OnBrowse"/>

            </StackPanel>
        </Border>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="2" Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,10,20">

            <Button Content="Cancel"
                    Width="100"
                    Margin="0,0,10,0"
                    Click="OnCancel"/>

            <Button Content="Open"
                    Width="100"
                    Click="OnOpen"/>

        </StackPanel>

    </Grid>
</Window>
