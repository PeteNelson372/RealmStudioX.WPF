                                </StackPanel>

                            </Button>

                        </StackPanel>
                    </Border>
                </Popup>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="Eraser"
            Grid.Row="3"
            Grid.Column="0"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
