                                                            Value="{x:Static rendering:LandformCoastlineStyle.UniformOutline}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>

                                            </Style>
                                        </TextBlock.Style>

