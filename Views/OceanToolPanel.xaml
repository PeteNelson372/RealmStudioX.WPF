<UserControl x:Class="RealmStudioX.WPF.Views.OceanToolPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="922" d:DesignWidth="152">

    <Border Background="#FFDFDBD2"
            Padding="10">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Header -->
                <RowDefinition Height="*"/>
                <!-- Content -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <TextBlock Text="Ocean Tools"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="Black"
                       Margin="0,0,0,8"/>

            <!-- Placeholder Content -->
            <TextBlock Grid.Row="1"
                       Text="Ocean tool controls will go here..."
                       Foreground="Black"
                       Opacity="0.7"
                       TextWrapping="Wrap"/>

        </Grid>

    </Border>

</UserControl>
