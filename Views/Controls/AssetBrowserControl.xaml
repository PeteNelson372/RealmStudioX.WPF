<UserControl x:Class="RealmStudioX.WPF.Views.Controls.AssetBrowserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:RealmStudioX.WPF.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">

    <Grid Width="140" Height="160">

        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Image + overlay buttons -->
        <Grid Grid.Row="0">

            <Border Background="#EEE"
                    CornerRadius="4"
                    Margin="4">
                <Image Source="{Binding ImageSource}"
                       Stretch="UniformToFill"/>
            </Border>

            <!-- Previous -->
            <Button Width="24"
                    Height="24"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="4,0,0,4"
                    Style="{StaticResource TextureBrowserButton}"
                    Command="{Binding PreviousCommand}">
                
                <materialDesign:PackIcon Kind="ChevronLeft"
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.8"/>
            </Button>

            <!-- Next -->
            <Button Width="24"
                    Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Margin="0,0,4,4"
                    Style="{StaticResource TextureBrowserButton}"
                    Command="{Binding NextCommand}">

                <materialDesign:PackIcon Kind="ChevronRight"
                    Width="16"
                    Height="16"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Opacity="0.8"/>
            </Button>

        </Grid>

        <!-- Asset Name -->
        <TextBlock Grid.Row="1"
                   Text="{Binding CurrentName}"
                   HorizontalAlignment="Center"
                   Margin="4,2,4,0"
                   FontSize="11"
                   Foreground="#FF45443F"
                   TextTrimming="CharacterEllipsis"
                   TextAlignment="Center"/>

    </Grid>
</UserControl>
