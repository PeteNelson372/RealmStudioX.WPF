<UserControl x:Class="RealmStudioX.WPF.Views.Controls.MainTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"             
             xmlns:local="clr-namespace:RealmStudioX.WPF.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="48" d:DesignWidth="1580">

    <DockPanel LastChildFill="True">
        <Image Source="/Assets/ico/realm_studio_icon.ico"
                    Width="36"
                    Height="36"
                    Margin="10,0,6,0"/>

        <!-- Window Buttons -->
        <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right">
            <!-- Minimize -->
            <Button Style="{StaticResource TitleBarButtonStyle}"
                    Click="OnMinimize" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets"/>
            </Button>

            <!-- Maximize -->
            <Button Style="{StaticResource TitleBarButtonStyle}"
                        Click="OnMaximize" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets"/>
            </Button>

            <!-- Close -->
            <Button Style="{StaticResource CloseButtonStyle}"
                    Click="OnExit" shell:WindowChrome.IsHitTestVisibleInChrome="True">
                <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets"/>
            </Button>

        </StackPanel>

        <!-- Center toolbar area -->
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="25,0,0,0">

            <TextBlock Text="Autosave"
                        Foreground="#CCCCCC"
                        VerticalAlignment="Center"
                        Margin="0,0,6,0"/>

            <CheckBox x:Name="AutosaveToggle"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Style="{StaticResource ToggleSwitchStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"/>

            <!-- Open -->
            <Button Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Margin="40,0,0,0"
                        Click="OnOpen" Width="32">

                <TextBlock Text="&#xE8E5;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="PaleGoldenrod"
                            FontSize="16"/>
            </Button>

            <!-- Save -->
            <Button Style="{StaticResource TitleBarButtonStyle}"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True"
                        Click="OnSave" Width="32">

                <TextBlock Text="&#xE74E;"
                            FontFamily="Segoe Fluent Icons"
                            Foreground="#FF31C731"
                            FontSize="16"/>
            </Button>

            <Button Style="{StaticResource TitleBarButtonStyle}"
                        ToolTip="Update available"
                        Click="UpdateAvailable_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">

                <Grid Width="32" Height="32">
                    <!-- Icon -->
                    <TextBlock Text="&#xE895;"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="#CCCCCC"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                    <!-- Badge -->
                    <Ellipse Width="6"
                                Height="6"
                                Fill="#4CAF50"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,6,6,0"/>
                </Grid>
            </Button>

        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- App Title -->
            <TextBlock Text="Realm Studio X"
                   Foreground="#E5E5E5"
                   FontSize="16"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,0,0"/>
        </StackPanel>

    </DockPanel>
</UserControl>
