<UserControl x:Class="RealmStudioX.WPF.Views.Controls.CompactPaletteControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border HorizontalAlignment="Left">
        <ItemsControl ItemsSource="{Binding Colors, RelativeSource={RelativeSource AncestorType=UserControl}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="16"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Width="15"
                            Height="15"
                            Margin="1.5"
                            Background="{Binding}"
                            BorderBrush="#666"
                            BorderThickness="1"
                            PreviewMouseLeftButtonDown="Color_Click"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </Border>

</UserControl>
