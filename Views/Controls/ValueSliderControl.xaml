<UserControl x:Class="RealmStudioX.WPF.Views.Controls.ValueSliderControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="20"
             Height="220"
             Focusable="True"
             FocusVisualStyle="{x:Null}">

    <Grid>
        <!-- Gradient -->
        <Border CornerRadius="3" ClipToBounds="True">
            <Rectangle x:Name="GradientRect"/>
        </Border>

        <!-- Marker -->
        <Canvas IsHitTestVisible="False">
            <!-- Outer -->
            <Ellipse x:Name="MarkerOuter"
                     Width="14"
                     Height="14"
                     Stroke="Black"
                     StrokeThickness="2"
                     Fill="Transparent"/>

            <!-- Inner -->
            <Ellipse x:Name="MarkerInner"
                     Width="10"
                     Height="10"
                     Stroke="White"
                     StrokeThickness="2"
                     Fill="Transparent"/>
        </Canvas>
    </Grid>
</UserControl>