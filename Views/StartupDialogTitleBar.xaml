<UserControl x:Class="RealmStudioX.WPF.Views.StartupDialogTitleBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"             
             xmlns:local="clr-namespace:RealmStudioX.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="48" d:DesignWidth="1580">

    <DockPanel LastChildFill="True">
        <Image Source="../Assets/realm_studio_icon.ico"
                    Width="36"
                    Height="36"
                    Margin="10,0,6,0"/>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

            <!-- App Title -->
            <TextBlock Text="Create or Select a Map"
                   Foreground="#E5E5E5"
                   FontSize="16"
                   FontWeight="SemiBold"
                   VerticalAlignment="Center"
                   Margin="0,0,0,0"/>
        </StackPanel>

    </DockPanel>
</UserControl>
