<UserControl x:Class="RealmStudioX.WPF.Views.MenuIconBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:local="clr-namespace:RealmStudioX.WPF.Views"
             mc:Ignorable="d" 
             d:DesignHeight="32" d:DesignWidth="276">
    <!-- RIGHT ICON BAR -->
    <StackPanel Orientation="Horizontal"
                DockPanel.Dock="Right">

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <materialDesign:PackIcon Kind="MapMarkerRadius"
                             Width="22"
                             Height="22"
                             Foreground="#FF8C0A0A"/>
        </Button>

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <TextBlock Text="WA"
                                FontFamily="Elephant"
                                FontSize="12"
                                Foreground="#FF8C0A0A"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
        </Button>

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <materialDesign:PackIcon Kind="CubeOutline"
                             Width="22"
                             Height="22"
                             Foreground="DarkGoldenrod"/>
        </Button>

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <materialDesign:PackIcon Kind="SelectDrag"
                             Width="22"
                             Height="22"
                             Foreground="Green"/>
        </Button>

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <materialDesign:PackIcon Kind="Palette"
                             Width="22"
                             Height="22"
                             Foreground="SaddleBrown"/>
        </Button>

        <Button Style="{StaticResource TitleBarButtonStyle}">
            <materialDesign:PackIcon Kind="Eyedropper"
                             Width="22"
                             Height="22"
                             Foreground="Black"/>
        </Button>

    </StackPanel>
</UserControl>
