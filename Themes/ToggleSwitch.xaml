<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
    <Setter Property="Width" Value="36"/>
    <Setter Property="Height" Value="18"/>
    <Setter Property="Cursor" Value="Hand"/>

    <Setter Property="Template">
        <Setter.Value>
            <ControlTemplate TargetType="CheckBox">
                <Grid Width="36" Height="18">

                    <!-- Track -->
                    <Border x:Name="SwitchTrack"
                            CornerRadius="9"
                            Background="#C84C4C"/>
                    <!-- OFF -->

                    <!-- Thumb -->
                    <Ellipse x:Name="SwitchThumb"
                                Width="14"
                                Height="14"
                                Fill="White"
                                Margin="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="ThumbTransform" X="0"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>

                </Grid>

                <ControlTemplate.Triggers>

                    <!-- ON -->
                    <Trigger Property="IsChecked" Value="True">

                        <!-- Animate ON -->
                        <Trigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                                Storyboard.TargetName="ThumbTransform"
                                                Storyboard.TargetProperty="X"
                                                To="16"
                                                Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.EnterActions>

                        <!-- Animate OFF -->
                        <Trigger.ExitActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                                Storyboard.TargetName="ThumbTransform"
                                                Storyboard.TargetProperty="X"
                                                To="0"
                                                Duration="0:0:0.18">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </Trigger.ExitActions>

                        <!-- Green ON -->
                        <Setter TargetName="SwitchTrack"
                                Property="Background"
                                Value="#4CAF50"/>

                    </Trigger>

                    <!-- Hover (subtle brighten) -->
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="SwitchTrack"
                                Property="Opacity"
                                Value="0.9"/>
                    </Trigger>

                    <!-- Disabled -->
                    <Trigger Property="IsEnabled" Value="False">
                        <Setter TargetName="SwitchTrack"
                                Property="Opacity"
                                Value="0.4"/>
                        <Setter TargetName="SwitchThumb"
                                Property="Opacity"
                                Value="0.6"/>
                    </Trigger>

                </ControlTemplate.Triggers>

            </ControlTemplate>
        </Setter.Value>
    </Setter>
    </Style>
</ResourceDictionary>