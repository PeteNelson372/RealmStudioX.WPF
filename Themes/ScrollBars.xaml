<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================
         Thumb (your original look)
         ========================= -->
    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="#888"
                            CornerRadius="3"
                            Width="6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"/>
                    <ControlTemplate.Triggers>

                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#AAA"/>
                        </Trigger>

                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#CCC"/>
                        </Trigger>

                        <!-- Horizontal thumb layout -->
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                     Value="Horizontal">
                            <Setter TargetName="ThumbBorder" Property="Height" Value="6"/>
                            <Setter TargetName="ThumbBorder" Property="Width" Value="Auto"/>
                            <Setter TargetName="ThumbBorder" Property="VerticalAlignment" Value="Center"/>
                            <Setter TargetName="ThumbBorder" Property="HorizontalAlignment" Value="Stretch"/>
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Arrow Buttons (unchanged)
         ========================= -->

    <Style x:Key="ScrollBarLineUpButton" TargetType="RepeatButton">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 6 L 4 2 L 8 6 Z"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarLineDownButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 2 L 4 6 L 8 2 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarLineLeftButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 6 0 L 2 4 L 6 8 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ScrollBarLineRightButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 2 0 L 6 4 L 2 8 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         SINGLE DEFAULT SCROLLBAR
         ========================= -->
    <Style TargetType="ScrollBar">

        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Opacity" Value="0.4"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">

                    <Grid>

                        <!-- Shared layout -->
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Decrease -->
                        <RepeatButton x:Name="DecreaseButton"
                                      Grid.Row="0"
                                      Grid.Column="1"
                                      Style="{StaticResource ScrollBarLineUpButton}"
                                      Command="ScrollBar.LineUpCommand"/>

                        <!-- THE ONLY TRACK -->
                        <Track x:Name="PART_Track"
                               Grid.Row="1"
                               Grid.Column="1"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}">

                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                            </Track.Thumb>

                        </Track>

                        <!-- Increase -->
                        <RepeatButton x:Name="IncreaseButton"
                                      Grid.Row="2"
                                      Grid.Column="1"
                                      Style="{StaticResource ScrollBarLineDownButton}"
                                      Command="ScrollBar.LineDownCommand"/>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- HORIZONTAL -->
                        <Trigger Property="Orientation" Value="Horizontal">

                            <Setter TargetName="DecreaseButton" Property="Grid.Row" Value="1"/>
                            <Setter TargetName="DecreaseButton" Property="Grid.Column" Value="0"/>
                            <Setter TargetName="DecreaseButton" Property="Style"
                                    Value="{StaticResource ScrollBarLineLeftButton}"/>
                            <Setter TargetName="DecreaseButton" Property="Command"
                                    Value="ScrollBar.LineLeftCommand"/>

                            <Setter TargetName="IncreaseButton" Property="Grid.Row" Value="1"/>
                            <Setter TargetName="IncreaseButton" Property="Grid.Column" Value="2"/>
                            <Setter TargetName="IncreaseButton" Property="Style"
                                    Value="{StaticResource ScrollBarLineRightButton}"/>
                            <Setter TargetName="IncreaseButton" Property="Command"
                                    Value="ScrollBar.LineRightCommand"/>

                            <Setter TargetName="PART_Track"
                                    Property="IsDirectionReversed"
                                    Value="False"/>

                            <Setter Property="Height" Value="10"/>
                        </Trigger>

                        <!-- VERTICAL -->
                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="PART_Track"
                                    Property="IsDirectionReversed"
                                    Value="True"/>
                            <Setter Property="Width" Value="10"/>
                        </Trigger>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>

</ResourceDictionary>