<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- =========================
         Thumb
         ========================= -->
    <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBorder"
                            Background="#888"
                            CornerRadius="3"
                            Width="6"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Stretch"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#AAA"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBorder" Property="Background" Value="#CCC"/>
                        </Trigger>

                        <!-- Horizontal -->
                        <DataTrigger Binding="{Binding Orientation, RelativeSource={RelativeSource AncestorType=ScrollBar}}"
                                     Value="Horizontal">
                            <Setter TargetName="ThumbBorder" Property="Height" Value="6"/>
                            <Setter TargetName="ThumbBorder" Property="Width" Value="Auto"/>
                            <Setter TargetName="ThumbBorder" Property="VerticalAlignment" Value="Center"/>
                            <Setter TargetName="ThumbBorder" Property="HorizontalAlignment" Value="Stretch"/>
                        </DataTrigger>

                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Arrow Buttons
         ========================= -->

    <!-- Up -->
    <Style x:Key="ScrollBarLineUpButton" TargetType="RepeatButton">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 6 L 4 2 L 8 6 Z"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Down -->
    <Style x:Key="ScrollBarLineDownButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 0 2 L 4 6 L 8 2 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Left -->
    <Style x:Key="ScrollBarLineLeftButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 6 0 L 2 4 L 6 8 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Right -->
    <Style x:Key="ScrollBarLineRightButton" TargetType="RepeatButton"
           BasedOn="{StaticResource ScrollBarLineUpButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent">
                        <Path Fill="#888"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Data="M 2 0 L 6 4 L 2 8 Z"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Base ScrollBar
         ========================= -->
    <Style x:Key="BaseScrollBarStyle" TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Opacity" Value="0.4"/>
    </Style>

    <!-- =========================
         Vertical ScrollBar
         ========================= -->
    <Style x:Key="VerticalScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource BaseScrollBarStyle}">

        <Setter Property="Orientation" Value="Vertical"/>
        <Setter Property="Width" Value="10"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Up -->
                        <RepeatButton Grid.Row="0"
                                      Style="{StaticResource ScrollBarLineUpButton}"
                                      Command="ScrollBar.LineUpCommand"/>

                        <!-- Track -->
                        <Track Grid.Row="1"
                               IsDirectionReversed="True"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}">

                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                            </Track.Thumb>

                        </Track>

                        <!-- Down -->
                        <RepeatButton Grid.Row="2"
                                      Style="{StaticResource ScrollBarLineDownButton}"
                                      Command="ScrollBar.LineDownCommand"/>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Horizontal ScrollBar
         ========================= -->
    <Style x:Key="HorizontalScrollBarStyle"
           TargetType="ScrollBar"
           BasedOn="{StaticResource BaseScrollBarStyle}">

        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Height" Value="10"/>

        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left -->
                        <RepeatButton Grid.Column="0"
                                      Style="{StaticResource ScrollBarLineLeftButton}"
                                      Command="ScrollBar.LineLeftCommand"/>

                        <!-- Track -->
                        <Track Grid.Column="1"
                               IsDirectionReversed="False"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}">

                            <Track.Thumb>
                                <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                            </Track.Thumb>

                        </Track>

                        <!-- Right -->
                        <RepeatButton Grid.Column="2"
                                      Style="{StaticResource ScrollBarLineRightButton}"
                                      Command="ScrollBar.LineRightCommand"/>

                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- =========================
         Default ScrollBar (ListBox, ScrollViewer)
         ========================= -->
    <Style TargetType="ScrollBar" BasedOn="{StaticResource BaseScrollBarStyle}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid>

                        <!-- VERTICAL LAYOUT -->
                        <Grid x:Name="VerticalLayout">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Up -->
                            <RepeatButton Grid.Row="0"
                                      Style="{StaticResource ScrollBarLineUpButton}"
                                      Command="ScrollBar.LineUpCommand"/>

                            <!-- Track -->
                            <Track x:Name="PART_Track"
                               Grid.Row="1"
                               IsDirectionReversed="True"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>

                            <!-- Down -->
                            <RepeatButton Grid.Row="2"
                                      Style="{StaticResource ScrollBarLineDownButton}"
                                      Command="ScrollBar.LineDownCommand"/>
                        </Grid>

                        <!-- HORIZONTAL LAYOUT -->
                        <Grid x:Name="HorizontalLayout" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left -->
                            <RepeatButton Grid.Column="0"
                                      Style="{StaticResource ScrollBarLineLeftButton}"
                                      Command="ScrollBar.LineLeftCommand"/>

                            <!-- Track -->
                            <Track x:Name="PART_Track_H"
                               Grid.Column="1"
                               IsDirectionReversed="False"
                               Maximum="{TemplateBinding Maximum}"
                               Minimum="{TemplateBinding Minimum}"
                               Value="{TemplateBinding Value}"
                               ViewportSize="{TemplateBinding ViewportSize}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                                </Track.Thumb>
                            </Track>

                            <!-- Right -->
                            <RepeatButton Grid.Column="2"
                                      Style="{StaticResource ScrollBarLineRightButton}"
                                      Command="ScrollBar.LineRightCommand"/>
                        </Grid>

                    </Grid>

                    <ControlTemplate.Triggers>

                        <!-- Switch layouts -->
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter TargetName="VerticalLayout" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="HorizontalLayout" Property="Visibility" Value="Visible"/>
                            <Setter Property="Height" Value="10"/>
                        </Trigger>

                        <Trigger Property="Orientation" Value="Vertical">
                            <Setter TargetName="VerticalLayout" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="HorizontalLayout" Property="Visibility" Value="Collapsed"/>
                            <Setter Property="Width" Value="10"/>
                        </Trigger>

                        <!-- Hover -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Opacity" Value="1"/>
                        </Trigger>

                    </ControlTemplate.Triggers>

                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>